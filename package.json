{
  "name": "scarlet-satellite-blog",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "worker": "tsx src/server/scheduled-post-worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1090.0",
    "@aws-sdk/s3-request-presigner": "3.1090.0",
    "@prisma/client": "6.19.2",
    "@tiptap/core": "3.28.0",
    "@tiptap/extension-image": "3.28.0",
    "@tiptap/extension-link": "3.28.0",
    "@tiptap/extension-table": "3.28.0",
    "@tiptap/extension-underline": "3.28.0",
    "@tiptap/html": "3.28.0",
    "@tiptap/pm": "3.28.0",
    "@tiptap/react": "3.28.0",
    "@tiptap/starter-kit": "3.28.0",
    "argon2": "0.44.0",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "nodemailer": "9.0.3",
    "otplib": "13.4.1",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "redis": "6.1.0",
    "prisma": "6.19.2",
    "sanitize-html": "2.17.6",
    "sharp": "0.35.3",
    "tsx": "4.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/nodemailer": "8.0.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
